# ──────────────────────────────────────────────────────────────────────────
# PyWorkflow Engine — Variables d'environnement
# Copiez ce fichier en `.env` et adaptez les valeurs.
# ──────────────────────────────────────────────────────────────────────────

# ── Data Lake ────────────────────────────────────────────────────────────
# Chemin racine du Data Lake. En dev local, pointe vers le dossier `data/datalake/`.
# En production, peut pointer vers S3 ou Azure Blob (à adapter dans DataLake).
DATALAKE_PATH=./data/datalake

# ── Data Warehouse ───────────────────────────────────────────────────────
# Backend du Data Warehouse : "duckdb" (dev) ou "postgres" (prod).
WAREHOUSE_BACKEND=duckdb
# Connection string ou chemin fichier.
# DuckDB  : ./data/warehouse/warehouse.duckdb
# Postgres : postgresql://user:password@host:5432/dbname
WAREHOUSE_CONN=./data/warehouse/warehouse.duckdb

# ── Sources — Stripe ────────────────────────────────────────────────────
# Clé API Stripe. Si vide, le StripeClient utilise des données mock (mode démo).
STRIPE_API_KEY=

# ── Notifications (optionnel) ───────────────────────────────────────────
# Webhook Slack pour les alertes pipeline
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Sources additionnelles (décommenter selon besoins) ──────────────────
# PG_CONNECTION_STRING=postgresql://user:password@host:5432/source_db
# SFTP_HOST=sftp.example.com
# SFTP_USER=data-team
# SFTP_PASSWORD=secret

# ── PyWorkflow Engine (core) ────────────────────────────────────────────
# LOG_LEVEL=INFO
# PYWORKFLOW_PERSISTENCE=sqlite
# PYWORKFLOW_DB_URL=sqlite:///workflow.db
